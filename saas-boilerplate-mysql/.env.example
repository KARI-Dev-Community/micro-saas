# Supabase — from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — from your Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID for your subscription plan (Stripe Dashboard > Product catalog)
STRIPE_PRICE_ID=

# Your app's base URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Billplz — Malaysian gateway (FPX/cards/e-wallets), lower fees than Stripe.
# Requires an SSM-registered Malaysian business — no individual accounts.
# Get these from your Billplz Dashboard (billplz.com) > Account Settings.
BILLPLZ_API_KEY=
BILLPLZ_X_SIGNATURE_KEY=
BILLPLZ_COLLECTION_ID=
# Amount to charge per billing cycle, in sen (RM29.00 = 2900)
BILLPLZ_PLAN_AMOUNT_CENTS=2900
# Set to "true" while testing against billplz-sandbox.com
BILLPLZ_SANDBOX=true

# Comma-separated emails allowed to view /admin (MRR dashboard)
ADMIN_EMAILS=you@example.com

# Sentry — error tracking and structured logging
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Needed only for uploading readable source maps (set in CI, not local dev)
SENTRY_AUTH_TOKEN=

# Upstash Redis — rate limiting on checkout/portal routes. Optional:
# rate limiting no-ops if these are unset, so it's safe to skip in dev.
# Create a free database at upstash.com > Redis.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend — transactional email (welcome + payment receipts). Optional:
# emails are skipped (logged only) if unset.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
